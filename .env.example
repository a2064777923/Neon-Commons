APP_NAME=DouDeZhu Online
# Public frontend origin used by the backend CORS policy during split-port runs.
APP_URL=http://127.0.0.1:3100
FRONTEND_PORT=3100
BACKEND_PORT=3101
PORT=3101
# Explicit browser REST origin. Leave blank in same-origin proxy deployments to auto-detect from window.location.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3101
# Legacy alias for NEXT_PUBLIC_API_BASE_URL when you want one shared backend origin variable.
NEXT_PUBLIC_BACKEND_URL=
# Explicit browser Socket.IO origin. Defaults to NEXT_PUBLIC_API_BASE_URL or same-origin/runtime detection.
NEXT_PUBLIC_SOCKET_URL=http://127.0.0.1:3101
JWT_SECRET=change-this-secret
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin123456
DATABASE_URL=postgres://postgres:postgres@postgres:5432/doudezhu
REDIS_URL=redis://redis:6379
